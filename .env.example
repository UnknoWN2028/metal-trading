# ============================================================
# 🔐 环境变量配置文件模板
# 复制此文件为 .env 并填入真实密钥
# .env 文件已在 .gitignore 中忽略，不会提交到 Git
# ============================================================

# DeepSeek API (https://platform.deepseek.com)
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# 上海期货交易所数据源 (可选，默认用 akshare 自动获取)
# SHFE_API_KEY=
